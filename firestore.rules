rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user's email is verified
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    // Get current user's UID
    function currentUserId() {
      return request.auth.uid;
    }
    
    // Check if user has a specific role (from custom claims)
    function hasRole(role) {
      return request.auth.token.role == role;
    }
    
    // Check if user is an admin
    function isAdmin() {
      return hasRole('admin');
    }
    
    // Check if user is a doctor
    function isDoctor() {
      return hasRole('doctor');
    }
    
    // Check if user is a patient
    function isPatient() {
      return hasRole('patient');
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return currentUserId() == userId;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    match /users/{userId} {
      // Users can read their own profile
      // Doctors can read their assigned patients
      // Admins can read all users
      allow read: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        (isDoctor() && resource.data.doctorId == currentUserId())
      );
      
      // Users can only update their own profile (limited fields)
      // Admins can update any user
      allow update: if isAuthenticated() && (
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isBlocked', 'doctorId'])) ||
        isAdmin()
      );
      
      // Only admins can create/delete users via Firestore
      // (Normal registration goes through Firebase Auth)
      allow create, delete: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // EXERCISES COLLECTION (Templates)
    // ============================================
    match /exercises/{exerciseId} {
      // All authenticated users can read exercises
      allow read: if isAuthenticated();
      
      // Only doctors and admins can create/modify exercises
      allow create, update, delete: if isAuthenticated() && (isDoctor() || isAdmin());
    }
    
    // ============================================
    // WORKOUTS COLLECTION (Patient-specific)
    // ============================================
    match /workouts/{workoutId} {
      // Patients can read their own workouts
      // Doctors can read workouts of their patients
      // Admins can read all
      allow read: if isAuthenticated() && (
        resource.data.patientId == currentUserId() ||
        resource.data.doctorId == currentUserId() ||
        isAdmin()
      );
      
      // Only doctors can create workouts for their patients
      allow create: if isAuthenticated() && (
        isDoctor() && 
        request.resource.data.doctorId == currentUserId()
      );
      
      // Doctors can update workouts they created
      // Patients can update completion status only
      allow update: if isAuthenticated() && (
        (isDoctor() && resource.data.doctorId == currentUserId()) ||
        (isPatient() && resource.data.patientId == currentUserId() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedAt', 'status', 'feedback']))
      );
      
      // Only the creating doctor or admin can delete
      allow delete: if isAuthenticated() && (
        (isDoctor() && resource.data.doctorId == currentUserId()) ||
        isAdmin()
      );
    }
    
    // ============================================
    // APPOINTMENTS COLLECTION
    // ============================================
    match /appointments/{appointmentId} {
      // Both doctor and patient can read their appointments
      allow read: if isAuthenticated() && (
        resource.data.patientId == currentUserId() ||
        resource.data.doctorId == currentUserId() ||
        isAdmin()
      );
      
      // Only doctors can create appointments
      allow create: if isAuthenticated() && isDoctor();
      
      // Doctor can update, patient can only update limited fields
      allow update: if isAuthenticated() && (
        (isDoctor() && resource.data.doctorId == currentUserId()) ||
        (isPatient() && resource.data.patientId == currentUserId() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['patientConfirmed', 'patientNotes']))
      );
      
      // Only doctor who created or admin can delete
      allow delete: if isAuthenticated() && (
        (isDoctor() && resource.data.doctorId == currentUserId()) ||
        isAdmin()
      );
    }
    
    // ============================================
    // VIDEOS COLLECTION (Exercise videos)
    // ============================================
    match /videos/{videoId} {
      // All authenticated users can read videos
      allow read: if isAuthenticated();
      
      // Only doctors and admins can manage videos
      allow create, update, delete: if isAuthenticated() && (isDoctor() || isAdmin());
    }
    
    // ============================================
    // AUDIT LOGS (Read-only for admins)
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if false; // Only backend can write via Admin SDK
    }
    
    // ============================================
    // DEFAULT DENY - Block everything else
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
