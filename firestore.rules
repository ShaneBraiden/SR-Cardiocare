rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Reads role from the user's Firestore doc (custom claims are not used).
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin()  { return isAuthenticated() && role() == 'admin';  }
    function isDoctor() { return isAuthenticated() && role() == 'doctor'; }
    function isPatient(){ return isAuthenticated() && role() == 'patient';}

    // ── Users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Own doc, or doctors/admins can list/read all users.
      allow read: if isAuthenticated() && (uid() == userId || isDoctor() || isAdmin());

      // Own profile updates — cannot touch role, isBlocked, assignedDoctorId.
      allow update: if isAuthenticated() && (
        (uid() == userId &&
          !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['role','isBlocked','assignedDoctorId'])) ||
        isDoctor() ||
        isAdmin()
      );

      // Doctors can create patient accounts; admins can do anything.
      allow create: if isAuthenticated() && (isDoctor() || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Exercises ─────────────────────────────────────────────────────────
    match /exercises/{exerciseId} {
      allow read:                    if isAuthenticated();
      allow create, update, delete:  if isDoctor() || isAdmin();
    }

    // ── Plans ─────────────────────────────────────────────────────────────
    match /plans/{planId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() ||
        resource.data.doctorId  == uid() ||
        isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isDoctor() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.doctorId == uid() || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.doctorId == uid() || isAdmin()
      );
    }

    // ── Assignments ───────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() ||
        resource.data.doctorId  == uid() ||
        isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isDoctor() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.doctorId == uid() || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.doctorId == uid() || isAdmin()
      );
    }

    // ── Session Logs ──────────────────────────────────────────────────────
    match /sessionLogs/{sessionId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() || isDoctor() || isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.patientId == uid();
      allow update: if isAuthenticated() && (
        resource.data.patientId == uid() || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Workouts ──────────────────────────────────────────────────────────
    match /workouts/{workoutId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() || isDoctor() || isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.patientId == uid();
      allow update: if isAuthenticated() && (
        resource.data.patientId == uid() || isDoctor() || isAdmin()
      );
      allow delete: if isDoctor() || isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow get:  if isAuthenticated() && (
        resource.data.userId == uid() || isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == uid();
      allow delete: if isAdmin();
    }

    // ── Appointments ──────────────────────────────────────────────────────
    match /appointments/{appointmentId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() ||
        resource.data.doctorId  == uid() ||
        isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isDoctor() || isAdmin();
      allow update: if isAuthenticated() && (
        resource.data.doctorId  == uid() ||
        (resource.data.patientId == uid() &&
          request.resource.data.diff(resource.data)
            .affectedKeys().hasOnly(['patientConfirmed','patientNotes'])) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        resource.data.doctorId == uid() || isAdmin()
      );
    }

    // ── Chat ──────────────────────────────────────────────────────────────
    match /chats/{patientId}/messages/{messageId} {
      allow read:   if isAuthenticated() && (
        uid() == patientId || isDoctor() || isAdmin()
      );
      allow create: if isAuthenticated() && (
        uid() == patientId || isDoctor() || isAdmin()
      );
      allow update, delete: if false;
    }

    // ── Doctor Feedback (doctor → patient) ────────────────────────────────
    match /feedback/{feedbackId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() ||
        resource.data.doctorId  == uid() ||
        isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isDoctor() || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── Post-Workout Feedback ─────────────────────────────────────────────
    match /postWorkoutFeedback/{feedbackId} {
      allow get:  if isAuthenticated() && (
        resource.data.patientId == uid() || isDoctor() || isAdmin()
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.patientId == uid();
      allow update, delete: if isAdmin();
    }

    // ── Login Logs ────────────────────────────────────────────────────────
    match /loginLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ── App Settings ──────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Videos ────────────────────────────────────────────────────────────
    match /videos/{videoId} {
      allow read:                   if isAuthenticated();
      allow create, update, delete: if isDoctor() || isAdmin();
    }

    // ── Audit Logs ────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
